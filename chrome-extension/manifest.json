{
    "manifest_version": 3,
    "name": "Accepta Auto-Filler",
    "version": "2.0",
    "description": "Auto-fills university application forms using data from your Accepta Vault.",
    "icons": {
        "16": "logo.png",
        "32": "logo.png",
        "48": "logo.png",
        "128": "logo.png"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "unlimitedStorage"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Accepta Vault",
        "default_icon": {
            "16": "logo.png",
            "32": "logo.png",
            "48": "logo.png",
            "128": "logo.png"
        }
    },
    "host_permissions": [
        "https://www.accepta.site/*",
        "https://accepta.site/*",
        "https://university-automation-app.vercel.app/*",
        "https://utfs.io/*",
        "https://*.ufs.sh/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://www.accepta.site/*",
                "https://accepta.site/*",
                "https://university-automation-app.vercel.app/*",
                "http://localhost:3000/*"
            ],
            "js": [
                "bridge.js"
            ]
        }
    ]
}
