// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String            @id @default(cuid())
  userId          String?           @unique // Clerk User ID
  fullName        String
  email           String            @unique
  phone           String?
  address         String?
  dob             DateTime?
  citizenship     String?
  zipCode         String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  isOnboardingComplete Boolean     @default(false)
  planType        String            @default("FREE") // FREE, SPRINT, SEASON
  expiresAt       DateTime?         // when the current pass expires; null on Free
  referralSource  String?           // "How did you find Accepta?" answer from signup
  utmSource       String?           // captured from the landing URL
  utmMedium       String?
  utmCampaign     String?
  interviewed     Boolean           @default(false) // user-research pipeline flag
  payments        Payment[]
  educations      Education[]
  testScores      TestScore[]
  extracurriculars Extracurricular[]
  documents       Document[]
  applications    Application[]
  recommendations Recommendation[]
  notes           ApplicationNote[]
}

model Education {
  id              String   @id @default(cuid())
  institutionName String
  major           String?
  city            String?
  country         String?
  startDate       DateTime?
  gradDate        DateTime?
  gpa             Float?
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TestScore {
  id         String    @id @default(cuid())
  testType   String    // e.g., SAT, ACT, IELTS, Duolingo
  score      String
  dateTaken  DateTime?
  expiryDate DateTime?
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Extracurricular {
  id           String   @id @default(cuid())
  role         String
  organization String
  startDate    DateTime?
  endDate      DateTime?
  hoursPerWeek Float?
  description  String?
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Document {
  id            String       @id @default(cuid())
  name          String
  type          String       // e.g., TRANSCRIPT, PASSPORT, RESUME
  fileUrl       String
  expiryDate    DateTime?
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Application {
  id                   String   @id @default(cuid())
  universityName       String
  major                String?
  programName          String?
  url                  String?
  deadline             String?
  matchScore           Int?
  status               String   @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, READY, SUBMITTED
  portalUrl            String?
  userId               String
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents            Document[]
  recommendations      Recommendation[]
  notes                ApplicationNote[]
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model ApplicationNote {
  id            String      @id @default(cuid())
  content       String
  category      String      @default("general") // general, todo, feedback, research
  isPinned      Boolean     @default(false)
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Recommendation {
    id               String       @id @default(cuid())
    recommenderName  String
    recommenderEmail String?
    recommenderTitle String?
    relationship     String       // e.g. "Professor", "Supervisor", "Mentor"
    status           String       @default("NOT_ASKED") // NOT_ASKED, ASKED, CONFIRMED, SUBMITTED, DECLINED
    applicationId    String?      // optional link to a specific application
    application      Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
    dueDate          DateTime?
    notes            String?
    askedDate        DateTime?
    reminderSent     Boolean      @default(false)
    userId           String
    user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt        DateTime     @default(now())
    updatedAt        DateTime     @updatedAt
}

model Payment {
  id        String   @id @default(cuid())
  txRef     String   @unique // Chapa transaction reference
  planType  String   // SPRINT, SEASON
  amount    Int      // ETB
  days      Int      // access days granted (30 or 90)
  status    String   @default("PENDING") // PENDING, COMPLETED, FAILED
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Opportunity {
  id              String   @id @default(cuid())
  userId          String?  // Clerk User ID if personal
  university      String
  programName     String
  description     String?
  deadline        DateTime?
  isScholarship   Boolean  @default(false)
  isFreeApp       Boolean  @default(false)
  country         String?
  link            String
  createdAt       DateTime @default(now())
}

