# Database (Postgres)
DATABASE_URL=
DIRECT_URL=

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# AI providers
GEMINI_API_KEY=
GROQ_API_KEY=

# File uploads
UPLOADTHING_TOKEN=

# Payments (Chapa)
CHAPA_SECRET_KEY=

# Direct bank/mobile-money transfer verification (https://verify.leul.et/docs)
# API key from the Verifier dashboard. Without it, transfer verification is disabled.
VERIFY_API_KEY=
# Base URL (optional — defaults to https://verifyapi.leulzenebe.pro)
VERIFY_API_URL=
# Comma-separated merchant accounts the transfer must be sent to (account numbers,
# phone numbers, and/or the exact account name). Receiver matching is skipped if empty.
# Example: 1000123456789,ACCEPTA PLC,0912345678
VERIFY_MERCHANT_ACCOUNTS=
# Max age (days) of a transfer receipt that can still be redeemed (default 30)
VERIFY_MAX_RECEIPT_AGE_DAYS=30
# Accounts shown to users in the "Pay by transfer" dialog ("Label: value" each)
NEXT_PUBLIC_VERIFY_PAY_CBE=
NEXT_PUBLIC_VERIFY_PAY_TELEBIRR=

# Public app URL used for Chapa return redirects in production
NEXT_PUBLIC_APP_URL=

# PostHog analytics (free cloud tier) — leave empty to disable analytics entirely
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Comma-separated emails for the /admin console.
# ADMIN_EMAILS      → super admins (everything: users, audit logs, deletes)
# DATA_ENTRY_EMAILS → data-entry admins (program entry console only)
ADMIN_EMAILS=
DATA_ENTRY_EMAILS=
